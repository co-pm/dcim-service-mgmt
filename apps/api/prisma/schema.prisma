generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ORG_OWNER
  ORG_ADMIN
  ADMIN
  SERVICE_MANAGER
  SERVICE_DESK_ANALYST
  ENGINEER
  CLIENT_VIEWER
  PUBLIC_USER
}

enum OwnerType {
  INTERNAL
  CLIENT
}

enum ServiceRequestStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  WAITING_CUSTOMER
  COMPLETED
  CLOSED
  CANCELLED
}

enum CheckStatus {
  DRAFT
  SCHEDULED
  ASSIGNED
  IN_PROGRESS
  PENDING_REVIEW
  COMPLETED
  CLOSED
  CANCELLED
}

enum CheckItemResponseType {
  PASS_FAIL
  PASS_FAIL_NA
}

enum IncidentStatus {
  NEW
  INVESTIGATING
  MITIGATED
  RESOLVED
  CLOSED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
}

enum RequestIntakeStatus {
  NEW
  UNDER_REVIEW
  CONVERTED
  REJECTED
}

enum AssetLifecycleState {
  PLANNED
  PROCUREMENT
  STAGING
  ACTIVE
  RETIRED
}

model Client {
  id        String   @id @default(uuid())
  organizationId String?
  organization Organization? @relation(fields: [organizationId], references: [id])
  name      String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  serviceRequests ServiceRequest[]
  assets    Asset[]
  checks             Check[]  @relation("ClientChecks")
  checkTemplates     CheckTemplate[] @relation("ClientCheckTemplates")
  incidents Incident[]
  tasks     Task[]
  sites     Site[]
  workPackages   WorkPackage[]
  changeRequests ChangeRequest[]
  risks          Risk[]
  issues         Issue[]
  publicSubmissions PublicSubmission[]
  documents DocumentReference[]
  requestIntakes RequestIntake[]
}

model Site {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  name      String
  address   String?
  city      String?
  postcode  String?
  country   String   @default("UK")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cabinets  Cabinet[]
  assets    Asset[]
  checks             Check[]  @relation("SiteChecks")
  checkTemplates     CheckTemplate[] @relation("SiteCheckTemplates")
  workPackageSites WorkPackageSite[]
}

model CheckTemplate {
  id                String   @id @default(uuid())
  reference         String   @unique
  name              String
  checkType         String
  description       String?
  clientId          String?
  client            Client?  @relation("ClientCheckTemplates", fields: [clientId], references: [id])
  siteId            String?
  site              Site?    @relation("SiteCheckTemplates", fields: [siteId], references: [id])
  isActive          Boolean  @default(true)
  estimatedMinutes  Int?
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  items             CheckTemplateItem[]
  checks            Check[]
}

model CheckTemplateItem {
  id                  String   @id @default(uuid())
  templateId          String
  template            CheckTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sortOrder           Int
  section             String?
  label               String
  guidance            String?
  responseType        CheckItemResponseType @default(PASS_FAIL)
  isRequired          Boolean  @default(true)
  isCritical          Boolean  @default(false)
  createdAt           DateTime @default(now())
}

model Check {
  id                 String      @id @default(uuid())
  reference          String      @unique
  clientId           String
  client             Client      @relation("ClientChecks", fields: [clientId], references: [id])
  siteId             String
  site               Site        @relation("SiteChecks", fields: [siteId], references: [id])
  templateId         String
  template           CheckTemplate @relation(fields: [templateId], references: [id])
  checkType          String
  title              String
  status             CheckStatus @default(DRAFT)
  priority           String      @default("medium")
  assigneeId         String?
  assignee           User?       @relation("AssignedCheck", fields: [assigneeId], references: [id])
  reviewerId         String?
  reviewer           User?       @relation("CheckReviewer", fields: [reviewerId], references: [id])
  scheduledAt        DateTime?
  startedAt          DateTime?
  submittedAt        DateTime?
  completedAt        DateTime?
  closedAt           DateTime?
  cancellationReason String?
  scopeNotes         String?
  engineerSummary    String?
  reviewerNotes      String?
  passRate           Float?
  createdById        String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  items              CheckItem[]
}

model CheckItem {
  id                  String   @id @default(uuid())
  checkId             String
  check               Check    @relation(fields: [checkId], references: [id], onDelete: Cascade)
  templateItemId      String?
  sortOrder           Int
  section             String?
  label               String
  guidance            String?
  responseType        CheckItemResponseType @default(PASS_FAIL)
  isRequired          Boolean  @default(true)
  isCritical          Boolean  @default(false)
  isAdHoc             Boolean  @default(false)
  response            String?
  notes               String?
  respondedAt         DateTime?
  respondedById       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  followOns           CheckItemFollowOn[]
}

model CheckItemFollowOn {
  id          String   @id @default(uuid())
  checkItemId String
  checkItem   CheckItem @relation(fields: [checkItemId], references: [id], onDelete: Cascade)
  entityType  String
  entityId    String
  note        String?
  createdById String?
  createdAt   DateTime @default(now())
}

model Cabinet {
  id        String   @id @default(uuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id])
  name      String
  type      String   @default("RACK")
  totalU    Int?
  usedU     Int?
  powerKw   Float?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets    Asset[]
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients   Client[]
  users     User[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  refreshTokenHash String?
  refreshTokenExpiresAt DateTime?
  role         Role
  organizationId String?
  organization Organization? @relation(fields: [organizationId], references: [id])
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedServiceRequests ServiceRequest[] @relation("AssignedSR")
  assignedIncidents Incident[] @relation("AssignedIncident")
  assignedTasks Task[] @relation("AssignedTask")
  requestIntakes RequestIntake[] @relation("RequesterIntake")
  assignedChanges  ChangeRequest[]  @relation("AssignedChange")
  changeApprovals  ChangeApproval[] @relation("ChangeApprovals")
  comments         Comment[]        @relation("UserComments")
  assignedChecks     Check[]  @relation("AssignedCheck")
  reviewingChecks    Check[]  @relation("CheckReviewer")
}

model PublicSubmission {
  id          String   @id @default(uuid())
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  requesterName  String
  requesterEmail String
  subject     String
  description String
  status      String   @default("NEW") // NEW / CONVERTED / REJECTED
  triageNotes String?
  convertedServiceRequestId String?
  convertedEntityType String?
  convertedEntityId   String?
  createdAt   DateTime @default(now())
}

model ServiceRequest {
  id          String   @id @default(uuid())
  reference   String   @unique
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  subject     String
  description String
  status      ServiceRequestStatus @default(NEW)
  priority    String   @default("medium")
  closureSummary String?
  assigneeId  String?
  assignee    User?    @relation("AssignedSR", fields: [assigneeId], references: [id])
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  comments  Comment[] @relation("ServiceRequestComments")

  auditEvents AuditEvent[]
}

model Asset {
  id               String    @id @default(uuid())
  assetTag         String    @unique
  name             String
  assetType        String
  ownerType        OwnerType
  clientId         String?
  client           Client?   @relation(fields: [clientId], references: [id])
  siteId           String?
  site             Site?     @relation(fields: [siteId], references: [id])
  cabinetId        String?
  cabinet          Cabinet?  @relation(fields: [cabinetId], references: [id])
  status           String    @default("ACTIVE")
  manufacturer     String?
  modelNumber      String?
  serialNumber     String?
  uHeight          Int?
  uPosition        Int?
  powerDrawW       Float?
  ipAddress        String?
  warrantyExpiry   DateTime?
  lifecycleState    AssetLifecycleState @default(ACTIVE)
  hyperviewAssetId  String?
  rackSide          String?             @default("FRONT")
  lastSyncedAt      DateTime?
  notes            String?
  locationType     String?
  locationArea     String?
  location         String?
  lastMaintenanceAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Incident {
  id          String   @id @default(uuid())
  reference   String   @unique
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  title       String
  description String
  status      IncidentStatus @default(NEW)
  severity    IncidentSeverity @default(MEDIUM)
  priority    String   @default("medium")
  assigneeId  String?
  assignee    User?    @relation("AssignedIncident", fields: [assigneeId], references: [id])
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       Task[]
}

model Task {
  id          String   @id @default(uuid())
  reference   String   @unique
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  title       String
  description String?
  status      TaskStatus @default(OPEN)
  priority    String   @default("medium")
  dueAt       DateTime?
  assigneeId  String?
  assignee    User?    @relation("AssignedTask", fields: [assigneeId], references: [id])
  incidentId  String?
  incident    Incident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  linkedEntityType String?
  linkedEntityId   String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DocumentReference {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  title       String
  url         String
  docType     String?
  version     String?
  linkedEntityType String?
  linkedEntityId   String?
  createdAt   DateTime @default(now())
}

model AuditEvent {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  action      String
  actorUserId String?
  clientId    String?
  data        Json?
  createdAt   DateTime @default(now())

  serviceRequestId String?
  serviceRequest   ServiceRequest? @relation(fields: [serviceRequestId], references: [id])
}

model RequestIntake {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  requesterUserId String?
  requesterUser   User? @relation("RequesterIntake", fields: [requesterUserId], references: [id])
  requesterName   String
  requesterEmail  String
  title       String
  description String
  category    String?
  impact      String?
  urgency     String?
  status      RequestIntakeStatus @default(NEW)
  triageNotes String?
  convertedEntityType String?
  convertedEntityId   String?
  convertedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkPackage {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  reference   String   @unique
  title       String
  type        String   @default("MANAGED_SERVICE")
  status      String   @default("ACTIVE")
  description String?
  startDate   DateTime?
  endDate     DateTime?
  value       Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sites       WorkPackageSite[]
}

model WorkPackageSite {
  id            String      @id @default(uuid())
  workPackageId String
  workPackage   WorkPackage @relation(fields: [workPackageId], references: [id])
  siteId        String
  site          Site        @relation(fields: [siteId], references: [id])
}

model ChangeRequest {
  id                  String   @id @default(uuid())
  reference           String   @unique
  clientId            String
  client              Client   @relation(fields: [clientId], references: [id])
  assigneeId          String?
  assignee            User?    @relation("AssignedChange", fields: [assigneeId], references: [id])
  changeType          String   @default("NORMAL")
  status              String   @default("DRAFT")
  priority            String   @default("medium")
  title               String
  description         String
  reason              String?
  impactAssessment    String?
  rollbackPlan        String?
  scheduledStart      DateTime?
  scheduledEnd        DateTime?
  actualStart         DateTime?
  actualEnd           DateTime?
  implementationNotes String?
  postImplReview      String?
  closedAt            DateTime?
  createdById         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  approvals     ChangeApproval[]
}

model ChangeApproval {
  id              String        @id @default(uuid())
  changeRequestId String
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id])
  approverId      String
  approver        User          @relation("ChangeApprovals", fields: [approverId], references: [id])
  decision        String
  notes           String?
  decidedAt       DateTime      @default(now())
}

model Risk {
  id             String   @id @default(uuid())
  reference      String   @unique
  clientId       String?
  client         Client?  @relation(fields: [clientId], references: [id])
  title          String
  description    String
  likelihood     String   @default("MEDIUM")
  impact         String   @default("MEDIUM")
  status         String   @default("IDENTIFIED")
  mitigationPlan String?
  acceptanceNote String?
  reviewDate     DateTime?
  closedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  source         String?
}

model Issue {
  id          String   @id @default(uuid())
  reference   String   @unique
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  title       String
  description String
  severity    String   @default("AMBER")
  status      String   @default("OPEN")
  resolution  String?
  reviewDate  DateTime?
  closedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Comment {
  id                String   @id @default(uuid())
  authorId          String
  author            User     @relation("UserComments", fields: [authorId], references: [id])
  body              String
  entityType        String
  entityId          String
  type              String   @default("WORK_NOTE")
  visibleToCustomer Boolean  @default(false)
  fromCustomer      Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  serviceRequestId  String?
  serviceRequest    ServiceRequest? @relation("ServiceRequestComments", fields: [serviceRequestId], references: [id])
}